{
  "name": "erpbridge",
  "version": "0.1.0",
  "private": true,
  "main": "start-electron.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron-dev": "node start-electron.js",
    "electron-build": "next build && electron-builder build --win"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "next": "16.2.0",
    "papaparse": "^5.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "resend": "^4.5.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "babel-plugin-react-compiler": "1.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4"
  },
  "build": {
    "appId": "com.erpbridge.app",
    "productName": "ERPBridge",
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "**/*",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**"
    ]
  }
}
